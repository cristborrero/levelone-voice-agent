# =============================================================================
# LIVEKIT
# =============================================================================
LIVEKIT_URL=wss://your-livekit-server.example.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# SIP Trunk credentials (LiveKit SIP <-> Telnyx)
LIVEKIT_SIP_TRUNK_USERNAME=your_sip_username
LIVEKIT_SIP_TRUNK_PASSWORD=your_sip_password
LIVEKIT_SIP_TRUNK_DOMAIN=sip.telnyx.com

# =============================================================================
# TELNYX
# =============================================================================
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_APP_ID=your_telnyx_sip_connection_id
TELNYX_PHONE_NUMBER=+441234567890
# Ed25519 public key — Telnyx portal → Messaging → Webhooks → "show public key" (base64)
# Leave empty to skip verification in development
TELNYX_WEBHOOK_PUBLIC_KEY=

# =============================================================================
# OPENAI (STT + primary LLM)
# =============================================================================
OPENAI_API_KEY=sk-proj-your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_STT_MODEL=whisper-1

# =============================================================================
# CARTESIA (TTS)
# =============================================================================
CARTESIA_API_KEY=sk_car_your_cartesia_api_key
CARTESIA_MODEL=sonic-english
# British English voice ID — replace with your cloned/chosen voice
CARTESIA_VOICE_ID=3c0f09d6-e0d7-499c-a594-70c5b7b93048

# =============================================================================
# GROQ (auxiliary LLM — free tier, Llama 3.3 70B)
# =============================================================================
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# =============================================================================
# HUBSPOT (CRM — Free tier)
# =============================================================================
HUBSPOT_ACCESS_TOKEN=pat-eu1-your_hubspot_token
HUBSPOT_OWNER_ID=your_hubspot_owner_id

# =============================================================================
# CAL.COM (booking)
# =============================================================================
CALCOM_API_KEY=cal_live_your_calcom_api_key
CALCOM_EVENT_TYPE_ID=your_calcom_event_type_id
CALCOM_USERNAME=your_calcom_username
CALCOM_BASE_URL=https://cal.com/your-username/discovery-call

# =============================================================================
# RESEND (transactional email)
# =============================================================================
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=alex@yourdomain.com
RESEND_FROM_NAME=Alex from LevelOne

# =============================================================================
# AGENT CONFIG
# =============================================================================
AGENT_NAME=Alex
AGENT_COMPANY=LevelOne Agency
AGENT_LANGUAGE=en-GB
AGENT_MAX_CALL_DURATION_SECONDS=600
AGENT_SILENCE_TIMEOUT_SECONDS=10
AGENT_TURN_DETECTION_THRESHOLD=0.5

# =============================================================================
# LLM ROUTER OVERRIDES (optional — overrides config/llm_config.yaml)
# =============================================================================
LLM_CONVERSATION_PROVIDER=openai
LLM_SUMMARIZATION_PROVIDER=groq
LLM_CLASSIFICATION_PROVIDER=groq
LLM_LEAD_SCORING_PROVIDER=groq
LLM_EMAIL_DRAFT_PROVIDER=groq

# =============================================================================
# APP
# =============================================================================
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json
DATABASE_URL=sqlite+aiosqlite:///./data/voice_agent.db
APP_HOST=0.0.0.0
APP_PORT=8080

# =============================================================================
# VONAGE
# =============================================================================

VONAGE_API_KEY=your_vonage_api_key

# =============================================================================
# VPS CONTAVO
# =============================================================================

VPS_USER=root
VPS_PASSWORD=your_vps_password
VPS_IP=your_vps_ip_address